{
    "name": "underscordle",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "description": "Daily guessing challenge game for Underscores music!",
    "scripts": {
        "dev": "vite dev",
        "dev:host": "vite dev --host",
        "build": "vite build",
        "preview": "pnpm build && wrangler pages dev .svelte-kit/cloudflare --d1 DB=underscordle",
        "db:generate": "drizzle-kit generate",
        "db:migrate:local": "wrangler d1 migrations apply DB --local",
        "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
        "lint": "prettier --check --write . && eslint . --fix",
        "scan": "node scripts/scan-songs.js",
        "generate": "node scripts/generate-daily.js",
        "convert": "node scripts/convert-masters.js",
        "bootstrap": "node scripts/bootstrap-registry.js"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@iconify-json/streamline-logos": "^1.2.0",
        "@sveltejs/adapter-auto": "^7.0.0",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.59.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^22",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.2",
        "flowbite-svelte-icons": "^3.1.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.4.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.2",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.3.3"
    },
    "keywords": [],
    "author": "angelolz",
    "license": "ISC",
    "packageManager": "pnpm@11.1.2",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "workerd"
        ]
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1037.0",
        "@fontsource/poppins": "^5.2.7",
        "@msgpack/msgpack": "^3.1.3",
        "@svelte-web-fonts/google": "^1.0.4",
        "@types/fluent-ffmpeg": "^2.1.28",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "fast-fuzzy": "^1.12.0",
        "fluent-ffmpeg": "^2.1.3",
        "mime": "^4.1.0",
        "music-metadata": "^11.12.3"
    }
}
