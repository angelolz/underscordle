{
    "name": "underscordle",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "description": "Daily guessing challenge game for Underscores music!",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "prettier --check . && eslint .",
        "lint:write": "prettier --check --write . && eslint .",
        "format": "prettier --write .",
        "scan": "node scripts/scan-songs.js",
        "generate": "node scripts/generate-daily.js",
        "convert": "node scripts/convert-masters.js"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-auto": "^7.0.0",
        "@sveltejs/kit": "^2.50.2",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^22",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.2",
        "flowbite-svelte-icons": "^3.1.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.4.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.2",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.3.1"
    },
    "keywords": [],
    "author": "angelolz",
    "license": "ISC",
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "@fontsource/poppins": "^5.2.7",
        "@svelte-web-fonts/google": "^1.0.4",
        "@types/fluent-ffmpeg": "^2.1.28",
        "fast-fuzzy": "^1.12.0",
        "fluent-ffmpeg": "^2.1.3",
        "music-metadata": "^11.12.3"
    }
}
